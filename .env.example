BROKERGATE_ENV=local
BROKERGATE_HOST=0.0.0.0
BROKERGATE_PORT=8000
BROKERGATE_API_KEY=change-me
BROKERGATE_CONFIRMATION_REQUIRED=true
BROKERGATE_BROKER_MODE=paper

# Tiger OpenAPI. Do not commit real values.
BROKERGATE_TIGER_ENABLED=false
BROKERGATE_TIGER_ACCOUNT=
BROKERGATE_TIGER_ID=
BROKERGATE_TIGER_LICENSE=
BROKERGATE_TIGER_PRIVATE_KEY_PATH=
BROKERGATE_TIGER_CONFIG_DIR=
BROKERGATE_TIGER_TOKEN_PATH=

# Longbridge OpenAPI. Do not commit real values.
BROKERGATE_LONGBRIDGE_ENABLED=false
BROKERGATE_LONGBRIDGE_APP_KEY=
BROKERGATE_LONGBRIDGE_APP_SECRET=
BROKERGATE_LONGBRIDGE_ACCESS_TOKEN=
BROKERGATE_LONGBRIDGE_ACCOUNT=

