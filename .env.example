OPENBROKER_ENV=local
OPENBROKER_HOST=0.0.0.0
OPENBROKER_PORT=8000
OPENBROKER_API_KEY=change-me
OPENBROKER_CONFIRMATION_REQUIRED=true
OPENBROKER_BROKER_MODE=paper

# Tiger OpenAPI. Do not commit real values.
OPENBROKER_TIGER_ENABLED=false
OPENBROKER_TIGER_ACCOUNT=
OPENBROKER_TIGER_ID=
OPENBROKER_TIGER_LICENSE=
OPENBROKER_TIGER_PRIVATE_KEY_PATH=
OPENBROKER_TIGER_CONFIG_DIR=
OPENBROKER_TIGER_TOKEN_PATH=

# Longbridge OpenAPI. Do not commit real values.
OPENBROKER_LONGBRIDGE_ENABLED=false
OPENBROKER_LONGBRIDGE_APP_KEY=
OPENBROKER_LONGBRIDGE_APP_SECRET=
OPENBROKER_LONGBRIDGE_ACCESS_TOKEN=
OPENBROKER_LONGBRIDGE_ACCOUNT=

